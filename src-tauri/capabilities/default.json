{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "deep-link:default",
    "log:default",
    "notification:default",
    "dialog:default",
    {
      "identifier": "fs:default",
      "allow": [
        {
          "path": "$DOWNLOAD"
        },
        {
          "path": "$DOWNLOAD/*"
        }
      ]
    }
  ]
}
